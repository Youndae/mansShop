<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.shop.mapper.MainMapper">

    <select id="mainBest" resultType="org.shop.domain.ProductVO">
            SELECT *
                    FROM(
                        SELECT *
                        FROM
                            product
                        ORDER BY pSalesRate DESC
                    )
            WHERE rownum BETWEEN 1 AND 12
    </select>

    <select id="productDetail" resultType="org.shop.domain.ProductVO">
        SELECT *
        FROM
            product
        WHERE
            pno=#{pno}
    </select>

    <select id="getProductThumb" resultType="org.shop.domain.ThumbnailVO">
        SELECT *
        FROM
            productThumbnail
        WHERE
            pno=#{pno}
    </select>

    <select id="getProductOp" resultType="org.shop.domain.ProductOpVO">
        SELECT *
        FROM
            productOp
        WHERE
            pno=#{pno}
    </select>

    <select id="getProductInfo" resultType="org.shop.domain.ProductImgVO">
        SELECT *
        FROM
            productImg
        WHERE
            pno=#{pno}
        ORDER BY pImgStep
    </select>

    <select id="getProductReview" resultType="org.shop.domain.ProductReviewVO">
        SELECT *
        FROM(
            SELECT
                rownum rn
                , r.*
            FROM(
                SELECT *
                FROM
                    productReview
                WHERE
                    pno=#{keyword}
                order by rnum desc
            )r
        )
        WHERE
            rn between (#{pageNum} - 1) * #{amount} + 1 AND #{pageNum} * #{amount}
    </select>

    <select id="getProductReviewTotal" resultType="int">
        SELECT count(*)
        FROM productReview
        WHERE
            pno=#{keyword}
    </select>

    <select id="pReviewCount" resultType="int">
        SELECT count(*)
        FROM
            productReview
        where
            pno=#{pno}
    </select>

    <select id="pQnACount" resultType="int">
        SELECT count(*)
        FROM
            productQnA
        WHERE
            pno=#{pno}
    </select>

</mapper>