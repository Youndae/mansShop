<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.shop.mapper.MainMapper">

    <select id="mainBest" resultType="org.shop.domain.ProductVO">
            SELECT *
                    FROM(
                        SELECT *
                        FROM
                            product
                        ORDER BY pSalesRate DESC
                    )
            WHERE rownum BETWEEN 1 AND 12
    </select>

    <select id="productDetail" resultType="org.shop.domain.ProductVO">
        SELECT *
        FROM
            product
        WHERE
            pno=#{pno}
    </select>

    <select id="getProductThumb" resultType="org.shop.domain.ThumbnailVO">
        SELECT *
        FROM
            productThumbnail
        WHERE
            pno=#{pno}
    </select>

    <select id="getProductOp" resultType="org.shop.domain.ProductOpVO">
        SELECT *
        FROM
            productOp
        WHERE
            pno=#{pno}
    </select>

</mapper>