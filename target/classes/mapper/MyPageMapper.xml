<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.shop.mapper.MyPageMapper">

    <resultMap id="memberMap" type="org.shop.domain.MemberVO">
        <id property="userId" column="userId"/>
        <result property="userId" column="userId"/>
        <result property="userPw" column="userPw"/>
        <result property="userName" column="userName"/>
        <result property="userEmail" column="userEmail"/>
        <result property="userBirth" column="userBirth"/>
        <result property="userPhone" column="userPhone"/>
        <collection property="authList" resultMap="authMap"></collection>
    </resultMap>

    <resultMap id="authMap" type="org.shop.domain.AuthVO">
        <result property="userId" column="userId"/>
        <result property="auth" column="auth"/>
    </resultMap>

    <select id="getModifyInfo" resultMap="memberMap">
        SELECT
            mem.userId, userPw, userName, userEmail, userBirth, userPhone, auth
        FROM
            member mem LEFT OUTER JOIN member_auth auth ON mem.userId = auth.userId
        WHERE
            mem.userId = #{userId}
    </select>

    <select id="getCartList" resultType="org.shop.domain.CartVO">
        SELECT
            c.cartNo
            , c.pOpNo
            , c.cCount
            , c.cPrice
            , p.pName
            , op.pSize
            , op.pColor
        FROM
            cart c
            INNER JOIN productOp op
                ON c.pOpNo = op.pOpNo
            INNER JOIN product p
                ON op.pno = p.pno
        WHERE
            c.userId = #{userId}
    </select>

    <delete id="deleteCart" parameterType="String">
        DELETE FROM cart
        WHERE
            userId=#{userId}
            AND
            pOpNo=#{pOpNo}
    </delete>

    <select id="memberOrderList" resultType="org.shop.domain.MemberOrderListDTO">
        <![CDATA[
            SELECT *
            FROM
                memberOrderList_view
            WHERE
                userId=#{userId}
                AND
                orderDate >= #{regDate}
        ]]>
    </select>

</mapper>